class Solution {
    public boolean isPerfectSquare(int n) {

        long low = 0 , high = n;
        
        while(low<=high){
            long mid = low+(high-low)/2;

            if(mid*mid == n){
                return true;
            }else if(mid*mid > n){
                high = mid-1;
            }else if(mid*mid < n){
                low = mid+1;
            }
        }
         return false;
    }
}
